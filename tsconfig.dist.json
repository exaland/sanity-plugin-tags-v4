{
  "extends": "./tsconfig.settings.json",
  "include": ["./src"],
  "exclude": [
    "./src/**/__fixtures__",
    "./src/**/__mocks__",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx"
  ],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "preserve",
    "module": "preserve",
    "noEmit": false,
    "noCheck": true,
    "emitDeclarationOnly": true
  }
}
